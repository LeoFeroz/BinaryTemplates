struct GDB1_HEADER {
    char    Format[4];
    uint32  null <format=hex>;
    uint32  DebugTextOffset <format=hex>;  //No Use Only Garabage
    int8    unknow;
    int8    NodesAmount; //Perhaps it's a GDB1 type, but all modelgdb use 4.
    int16   null;
    int32   null;
    NodeParameter_TYPE   ParameterType;
    uint32  Node_MeshOptions_StartOffset <format=hex>;
    uint32  Node_Materials_StartOffset <format=hex>;
    uint32  Node_Geometry_StartOffset <format=hex>;
    uint32  Node_Nodes_StartOffset <format=hex>;
} header;

struct Vectors_Struct(int value) {
    
    switch (value) {
        case 2:
        float VariableValue[2];
            break;
        case 3:
        float VariableValue[3];
            break;
        case 4:
        float VariableValue[4];
            break;  
        case 5:
        float Value[16];
            break;
        default:
        float VariableValue;
            break;
    }
};

struct SubMatValue_Struct {
    VARIABLE_TYPE VariableType;
    switch (VariableType) {
        case TYPE_Matrix:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Mtx(5);
            break;
        case TYPE_Vector2:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec2f(2);
            break;
        case TYPE_Vector3:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec3f(3);
            break;
        case TYPE_Vector4:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec4f(4);
            break;
        case TYPE_Colour:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            uint8 Colour[4];
            break;
        case TYPE_Bool:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Bool_Struct VariableValue;
            break;
        case TYPE_Float32:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            float VariableValue;
            break;
        case TYPE_String:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            int32 StringSize;
            char MatName[StringSize];
            break;
        case TYPE_UInt32:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            if (ParameterType == ResourceID) {
                uint32 TextureID <format=hex>;
            } else {
                uint32 VariableValue <format=hex>;
            }
            break;
        default:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            int32 VariableValue;
            break;
    }
};

struct MatValue_Struct {
    VARIABLE_TYPE VariableType;
    switch (VariableType) {
        case TYPE_Node:
            int8 ParamNum;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            local int i;
            if (ParameterType == Node_Texture3) {
                break;
            }
            uint32 ParamOffset[ParamNum] <format=hex>;
            
            for (i = 0; i < ParamNum; i++)
            {
                if (ParamOffset[i] > 0)
                {
                     FSeek(ParamOffset[i]);

                        SubMatValue_Struct SubNodeValues;

                }
             }

            break;
         case TYPE_Array:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            int32 ArrayElements;
            VARIABLE_TYPE VariableType;
            int8 null;
            int8 null;
            int8 null;
            int32 value[ArrayElements];
            int32 unkflag;
            break;
         case TYPE_Matrix:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Mtx(5);
            break;
        case TYPE_Vector2:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec2f(2);
            break;
        case TYPE_Vector3:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec3f(3);
            break;
        case TYPE_Vector4:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Vectors_Struct Vec4f(4);
            break;
        case TYPE_Bool:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            Bool_Struct VariableValue;
            break;
        case TYPE_Float32:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            float VariableValue;
            break;
        case TYPE_String:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            int32 StringSize;
            char MatName[StringSize];
            break;
        case TYPE_UInt32:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            uint32 VariableValue <format=hex>;
            break;
        default:
            int8 null;
            int8 null;
            int8 null;
            int32 unkflag;
            NodeParameter_TYPE ParameterType;
            int32 VariableValue;
            break;
    }
};

struct NodesNodes_Struct {
    VARIABLE_TYPE StructType;
    int8 NodesParameterTotal;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32 NodesPararmeterOffset[NodesParameterTotal] <format=hex>;
    
    local int i;
    for (i = 0; i < NodesParameterTotal; i++)
    {
        if (NodesPararmeterOffset[i] > 0)
        {
            FSeek(NodesPararmeterOffset[i]);

            MatValue_Struct NodeValues;

        }
    }
};

struct Material_Struct {
    VARIABLE_TYPE StructType;
    int8 MatParameterTotal;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32 MatPararmeterOffset[MatParameterTotal] <format=hex>;
    
    local int i;
    for (i = 0; i < MatParameterTotal; i++)
    {
        if (MatPararmeterOffset[i] > 0)
        {
            FSeek(MatPararmeterOffset[i]);

            MatValue_Struct NodeValues;

        }
    }
};

struct GeoValue_Struct { 

    VARIABLE_TYPE VariableType;
    int8 null;
    int8 null;
    int8 null;
    int32 unkflag;
    NodeParameter_TYPE ParameterType;
    
    switch (VariableType) {
        case 5:
            int32 VariableValue;
            break;
        case 13:
            float FloatVaraibleValue[4];
            break;
        default:
            int32 VariableValue;
            break;
        
    }
};

struct Geometry_Struct {
    VARIABLE_TYPE StructType;
    int8  GeoParamNum;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32 GeoPararmeterOffset[GeoParamNum] <format=hex>;
    
    local int i;
    for (i = 0; i < GeoParamNum; i++)
    {
        if (GeoPararmeterOffset[i] > 0)
        {
            FSeek(GeoPararmeterOffset[i]);

            MatValue_Struct NodeValues;

        }
    }
};

struct Node_Geometrie {
    VARIABLE_TYPE StructType; 
    int8 MeshesNum;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32 MeshPararmeterOffset[MeshesNum] <format=hex>;
    local int i;

    for (i = 0; i < MeshesNum; i++)
    {
        if (MeshPararmeterOffset[i] > 0)
        {
            FSeek(MeshPararmeterOffset[i]);

            Geometry_Struct Node_Geometry;
        }
    }
};

struct Node_MeshOptions {
    VARIABLE_TYPE StructType;   
    int8  OptionsNum;
    int8 null;
    int8 null;
    int32 unkflag;
    NodeParameter_TYPE NodeType;
    uint32  OptionsStartOffset[OptionsNum] <format=hex>;
    local int i;

    for (i = 0; i < OptionsNum; i++)
    {
        if (OptionsStartOffset[i] > 0)
        {
          FSeek(OptionsStartOffset[i]);
    
           MatValue_Struct Node_Values;
        }
    }
};

struct Node_Materials {
    VARIABLE_TYPE StructType;   
    int8  MaterialNum;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32  MaterialsStartOffset[MaterialNum] <format=hex>;
    local int i;

    for (i = 0; i < MaterialNum; i++)
    {
        if (MaterialsStartOffset[i] > 0)
        {
          FSeek(MaterialsStartOffset[i]);
    
           Material_Struct Node_Material;
        }
    }
};

struct Node_Nodes {
    VARIABLE_TYPE StructType;   
    int8  NodesNum;
    int16 null;
    int32 flag;
    NodeParameter_TYPE NodeType;
    uint32  NodesStartOffset[NodesNum] <format=hex>;
    local int i;

    for (i = 0; i < NodesNum; i++)
    {
        if (NodesStartOffset[i] > 0)
        {
          FSeek(NodesStartOffset[i]);
    
           NodesNodes_Struct Node_Node;
        }
    }
};

FSeek(header.Node_MeshOptions_StartOffset);
Node_MeshOptions i0 <name="Node_MeshOptions">;

FSeek(header.Node_Materials_StartOffset);
Node_Materials   i1 <name="Node_Materials">;

FSeek(header.Node_Geometry_StartOffset);
Node_Geometrie Node_Geometries;

FSeek(header.Node_Nodes_StartOffset);
Node_Nodes       i3 <name="Node_Nodes">;