    VertexFormat = 64946207;  // Pos + Normal + Color + Tangent + TexCoord
    VertexFormat = 144310319; // Pos + Normal + Color + TexCoord + TexCoord1
    VertexFormat = 215941167; // Pos + Normal + Color + TexCoord + TexCoord1
    VertexFormat = 176816187; // Pos + Normal + Tangent + TexCoord + TexCoord1
    VertexFormat = 265224251; // Pos + Normal + Tangent + TexCoord + TexCoord1
*/
//------------------------------------------------

enum <int8> VARIABLE_TYPE {
    TYPE_Array    = 1,
    TYPE_Bool     = 3,
    TYPE_Int32    = 5,
    TYPE_Matrix   = 6,
    TYPE_Node     = 7,
    TYPE_Vector2  = 11,
    TYPE_Vector3  = 12,
    TYPE_Vector4  = 13,
    TYPE_Colour   = 14,
    TYPE_String   = 9,
    TYPE_Float32  = 4,
    TYPE_UInt32   = 15,
};

enum <int32> Bool_Struct {
    False = 0,
    True  = 1,
};

